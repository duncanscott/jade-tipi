# Jade-Tipi local environment example.
# Do not commit real credentials. In the orchestrator workspace, put shared
# values in ../config/env/project.env.local so agent-orchestrator can
# materialize worktree .env files before agent invocation.

# Local CouchDB single-node admin (used by the docker compose `couchdb`
# service only; the container binds to 127.0.0.1:5984). These are
# non-secret placeholders for loopback-only local development; override
# in the worktree .env if a non-default local admin is desired.
COUCHDB_USER=admin
COUCHDB_PASSWORD=admin

# Remote JGI CouchDB sources for replication into local databases.
# Provide real values in the worktree .env (never commit).
JADE_TIPI_COUCHDB_CLARITY_URL=https://pps-couch-prd.jgi.lbl.gov:6984/clarity
JADE_TIPI_COUCHDB_ESP_ENTITY_URL=https://pps-couch-prd.jgi.lbl.gov:6984/esp-entity
JADE_TIPI_COUCHDB_DAP_SEQ_URL=https://pps-couch-prd.jgi.lbl.gov:6984/dap-seq
JADE_TIPI_COUCHDB_ADMIN_USERNAME=
JADE_TIPI_COUCHDB_ADMIN_PASSWORD=
